{
  "cleanUrls": true,
  "builds": [
    { "src": "api/feed.js", "use": "@vercel/node" },
    { "src": "api/cron.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "articles.json", "use": "@vercel/static" },
    { "src": "favicon.svg", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/feed", "dest": "/api/feed.js" },
    { "src": "/api/cron", "dest": "/api/cron.js" }
  ],
  "headers": [
    {
      "source": "/articles.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=180, s-maxage=300, stale-while-revalidate=600"
        }
      ]
    }
  ]
}
