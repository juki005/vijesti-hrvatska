{
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/feed.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/feed",
      "dest": "/api/feed.js"
    }
  ]
}
